<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.integration.modules.emr.mapper.EmrDesignerMapper">
    <!-- 查询所有的文书分类 -->
    <select id="getEmrCategory" resultType="cn.net.integration.modules.emr.entity.EmrCategory">
        select *
        from t_sys_user
        where username = #{username}
    </select>
</mapper>