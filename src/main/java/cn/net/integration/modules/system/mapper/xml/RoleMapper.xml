<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.net.integration.modules.system.mapper.RoleMapper">
    <!-- 插入用户角色关系 -->
    <insert id="addUserRole" parameterType="cn.net.integration.modules.system.entity.SysRole">
        insert into integration.t_sys_user_role (id, user_id, role_id)
        VALUES (#{id}, #{userId}, #{roleId})
    </insert>
</mapper>